    <image name="background" extra="true">
      <path>./_assets/white.png</path>
      <color>${colorBg}</color>
      <size>1 1</size>
      <pos>0 0</pos>
      <zIndex>0</zIndex>
    </image>

    <!-- 왼쪽 사이드바 -->
