  <!-- 비디오 뷰 전용 -->
  <feature supported="video">
  <view name="video">

    <!-- video 뷰에서 md_image 숨김 (video 요소가 스냅샷 담당) -->
    <image name="md_image">
      <pos>1.5 1.5</pos>
      <size>0 0</size>
    </image>

    <video name="md_video">
      <pos>0.783 0.340</pos>
      <origin>0.5 0.5</origin>
      <maxSize>0.320 0.280</maxSize>
      <delay>1.5</delay>
      <showSnapshotNoVideo>true</showSnapshotNoVideo>
      <showSnapshotDelay>true</showSnapshotDelay>
      <zIndex>10</zIndex>
    </video>

  </view>
  </feature>


