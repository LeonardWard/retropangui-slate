<?xml version="1.0"?>
<theme>
  <formatVersion>4</formatVersion>
  <resolution>1920 1080</resolution>

  <variables>
    <colorBg>F2F3F4FF</colorBg>
    <!-- 2026-07-11: 원래 E8EAEE는 colorBg(F2F3F4)와 채널당 10 정도밖에 안
         차이나서, 실기기 모니터에서 그 경계에 디더링/밴딩 아티팩트가 보임
         (kmsgrab 캡처엔 안 잡힘 - GPU 프레임버퍼는 정상이라 디스플레이 쪽
         후처리 문제로 추정, ES 절전모드로 화면이 어두워지면 사라지는 것도
         이 가설과 일치). 차이를 채널당 ~20으로 벌려서 안전하게 함 -
         sidebar-rounded.svg의 fill도 이 값과 반드시 같이 맞출 것. -->
    <colorSidebar>DCDEE2FF</colorSidebar>
    <colorDark>1A1E2DFF</colorDark>
    <colorLogo>1C1F2CFF</colorLogo>
    <colorAccent>2D5BE3FF</colorAccent>
    <colorBlue>4A8FE7FF</colorBlue>
    <colorGray1>9CA8B7FF</colorGray1>
    <colorGray2>6B7A8EFF</colorGray2>
    <colorGray3>4A5568FF</colorGray3>
    <colorDivider>D5DAE6FF</colorDivider>

    <!-- 2026-07-17: 시스템별 최신 스크린샷 경로 - 셸 커맨드 결과(ls -t로 찾은
         최신 파일)를 그대로 값으로 씀. 복사/훅 스크립트 없이 테마가 스스로
         screenshots/<시스템>/ 폴더를 들여다봄(ThemeData.cpp parseVariables()의
         exec 속성 지원). $RETROPANGUI_SHARE는 ES 프로세스 환경변수(ES의
         ${} 치환이 아니라 셸 자체의 변수 확장) - S99emulationstation이 export.
         스크린샷이 하나도 없으면 빈 문자열 → 아래 image가 <default> 없이
         조용히 빈 화면으로 남음(의도된 동작, 크래시/에러 없음). -->
    <latestScreenshot exec="ls -t $RETROPANGUI_SHARE/screenshots/${system.name}/*.png 2>/dev/null | head -1"/>
  </variables>

  <!-- 게임목록류 화면(basic/detailed/video/grid) - 위치/크기/폰트는 이 파일 안에 -->
  <include>./_inc/gamelist-view.xml</include>

  <!-- 메인 시스템 화면(system) - 위치/크기/폰트는 이 파일 안에 -->
  <include>./_inc/system-view.xml</include>

</theme>
