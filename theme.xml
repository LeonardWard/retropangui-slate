      <path>./_assets/white.png</path>
      <color>${colorSidebar}</color>
      <size>0.243 1.0</size>
      <pos>0 0</pos>
      <zIndex>5</zIndex>
    </image>

    <!-- 상단 헤더바 (화이트) -->
    <image name="header-bar" extra="true">
      <path>./_assets/white.png</path>
      <color>${colorBg}</color>
      <size>0.757 0.137</size>
      <pos>0.243 0</pos>
      <zIndex>6</zIndex>
    </image>

    <!-- 하단 풋터바 (화이트) -->
