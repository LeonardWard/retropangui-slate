  <!-- 캐러셀 지원 시 -->
  <feature supported="carousel">
  <view name="system">

    <!-- 세로형 캐러셀 (좌측 사이드바 전체) -->
    <carousel name="systemcarousel">
      <type>vertical</type>
      <pos>0.09 0.515</pos>
      <origin>0.5 0.5</origin>
      <size>0.18 0.88</size>
      <color>00000000</color>
      <colorEnd>00000000</colorEnd>
      <logoSize>0.155 0.090</logoSize>
      <logoScale>1.12</logoScale>
      <maxLogoCount>7</maxLogoCount>
      <zIndex>20</zIndex>
    </carousel>

    <!-- 큰 시스템 로고 (메인 영역 좌측 상단) -->
    <image name="logo">
      <path>./_assets/logos/${system.theme}.svg</path>
      <origin>0 0.5</origin>
      <pos>0.215 0.190</pos>
      <maxSize>0.36 0.12</maxSize>
      <zIndex>15</zIndex>
    </image>

