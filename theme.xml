      <pos>0.1279 0.0685</pos>
      <maxSize>0.230 0.070</maxSize>
      <zIndex>10</zIndex>
    </image>

    <!-- 헤더 하단 구분선 -->
    <image name="header-divider" extra="true">
      <path>./_assets/white.png</path>
      <color>00000000</color>
      <size>0.757 0.002</size>
      <pos>0.243 0.137</pos>
