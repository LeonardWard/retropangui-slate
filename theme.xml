      <pos>0.668 0.603</pos>
      <size>0.310 0.026</size>
      <fontSize>0.015</fontSize>
      <color>${colorGray3}</color>
      <zIndex>10</zIndex>
    </text>

    <!-- 퍼블리셔 레이블 -->
