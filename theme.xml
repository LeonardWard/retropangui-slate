<?xml version="1.0"?>
<theme>
  <formatVersion>4</formatVersion>

  <!-- ===== GAMELIST VIEW (basic / detailed / video / grid) ===== -->
  <view name="basic, detailed, video, grid">

    <!-- 전체 배경 -->
    <image name="background" extra="true">
      <path>./_assets/white.png</path>
      <color>EEF1F7FF</color>
      <size>1 1</size>
      <pos>0 0</pos>
      <zIndex>0</zIndex>
    </image>

    <!-- 왼쪽 다크 사이드바 -->
    <image name="sidebar" extra="true">
      <path>./_assets/white.png</path>
      <color>1A1E2DFF</color>
      <size>0.18 1.0</size>
      <pos>0 0</pos>
      <zIndex>5</zIndex>
    </image>

    <!-- 상단 헤더바 (화이트) -->
    <image name="header-bar" extra="true">
      <path>./_assets/white.png</path>
      <color>FFFFFFFF</color>
      <size>0.82 0.065</size>
      <pos>0.18 0</pos>
      <zIndex>6</zIndex>
    </image>

    <!-- 앱 로고 (사이드바 상단, 흰색) -->
    <image name="appname-logo" extra="true">
      <path>./_assets/logo-header.svg</path>
      <origin>0.5 0.5</origin>
      <pos>0.09 0.033</pos>
      <maxSize>0.155 0.038</maxSize>
      <zIndex>10</zIndex>
    </image>

    <!-- 헤더 하단 구분선 (메인 영역만) -->
    <image name="header-divider" extra="true">
      <path>./_assets/white.png</path>
      <color>D5DAE6FF</color>
      <size>0.82 0.002</size>
      <pos>0.18 0.065</pos>
      <zIndex>7</zIndex>
    </image>

    <!-- 사이드바 세로 구분선 -->
    <image name="sidebar-divider" extra="true">
      <path>./_assets/white.png</path>
      <color>D5DAE6FF</color>
      <size>0.001 0.935</size>
      <pos>0.18 0.065</pos>
      <zIndex>7</zIndex>
    </image>

    <!-- 리스트-디테일 구분선 -->
    <image name="list-detail-divider" extra="true">
      <path>./_assets/white.png</path>
      <color>D5DAE6FF</color>
      <size>0.001 0.935</size>
      <pos>0.53 0.065</pos>
      <zIndex>7</zIndex>
    </image>

    <!-- 사이드바 내 시스템 로고 -->
    <image name="logo">
      <path>./_assets/logos/${system.theme}.svg</path>
      <origin>0.5 0.5</origin>
      <pos>0.09 0.09</pos>
      <maxSize>0.155 0.065</maxSize>
      <color>FFFFFFFF</color>
      <zIndex>15</zIndex>
    </image>

    <!-- 사이드바: 시스템 짧은 설명 -->
    <text name="shortdescription" extra="true">
      <origin>0.5 0.5</origin>
      <pos>0.09 0.18</pos>
      <size>0.165 0.04</size>
      <fontSize>0.014</fontSize>
      <fontPath>./_assets/fonts/Pretendard-Regular.ttf</fontPath>
      <color>9CA8B7FF</color>
      <alignment>center</alignment>
      <forceUppercase>0</forceUppercase>
      <zIndex>10</zIndex>
    </text>

    <!-- 사이드바: 시스템 긴 설명 -->
    <text name="longdescription" extra="true">
      <origin>0.5 0</origin>
      <pos>0.09 0.235</pos>
      <size>0.165 0.275</size>
      <fontSize>0.014</fontSize>
      <fontPath>./_assets/fonts/Pretendard-Regular.ttf</fontPath>
      <color>6B7A8EFF</color>
      <lineSpacing>1.5</lineSpacing>
      <forceUppercase>0</forceUppercase>
      <alignment>center</alignment>
      <zIndex>10</zIndex>
    </text>

    <!-- 사이드바 하단: 시스템 정보 (게임 수 등) -->
    <text name="systemInfo">
      <origin>0.5 0.5</origin>
      <pos>0.09 0.80</pos>
      <size>0.165 0.06</size>
      <fontSize>0.015</fontSize>
      <fontPath>./_assets/fonts/Pretendard-Regular.ttf</fontPath>
      <color>9CA8B7FF</color>
      <alignment>center</alignment>
      <zIndex>10</zIndex>
    </text>

    <!-- ── 게임 목록 ── -->
    <textlist name="gamelist">
      <pos>0.195 0.080</pos>
      <size>0.325 0.852</size>
      <primaryColor>4A5568FF</primaryColor>
      <secondaryColor>718096FF</secondaryColor>
      <selectedColor>2D5BE3FF</selectedColor>
      <selectorColor>E8F0FEEE</selectorColor>
      <selectorHeight>0.042</selectorHeight>
      <fontPath>./_assets/fonts/Pretendard-Regular.ttf</fontPath>
      <fontSize>0.020</fontSize>
      <alignment>left</alignment>
      <horizontalMargin>0.015</horizontalMargin>
      <lineSpacing>1.5</lineSpacing>
      <forceUppercase>0</forceUppercase>
      <zIndex>10</zIndex>
    </textlist>

    <!-- ── 우측 상세 패널 ── -->

    <!-- 게임 이름 (헤더 영역) -->
    <text name="md_name">
      <pos>0.545 0.074</pos>
      <size>0.44 0.035</size>
      <fontSize>0.022</fontSize>
      <fontPath>./_assets/fonts/Pretendard-Bold.ttf</fontPath>
      <color>1A1E2DFF</color>
      <zIndex>10</zIndex>
    </text>

    <!-- 게임 스크린샷 이미지 -->
    <image name="md_image">
      <origin>0.5 0.5</origin>
      <pos>0.762 0.295</pos>
      <maxSize>0.44 0.40</maxSize>
      <zIndex>10</zIndex>
    </image>

    <!-- 메타데이터 레이블 공통 스타일 -->
    <text name="md_lbl_rating, md_lbl_developer, md_lbl_publisher, md_lbl_players, md_lbl_releasedate, md_lbl_genre">
      <fontPath>./_assets/fonts/Pretendard-Regular.ttf</fontPath>
      <fontSize>0.015</fontSize>
      <color>9CA8B7FF</color>
      <forceUppercase>0</forceUppercase>
      <zIndex>10</zIndex>
    </text>

    <!-- 출시일 레이블 -->
    <text name="md_lbl_releasedate">
      <pos>0.545 0.555</pos>
      <size>0.09 0.026</size>
    </text>
    <!-- 출시일 -->
    <datetime name="md_releasedate">
      <fontPath>./_assets/fonts/Pretendard-Regular.ttf</fontPath>
      <pos>0.640 0.555</pos>
      <size>0.10 0.026</size>
      <fontSize>0.015</fontSize>
      <color>4A5568FF</color>
      <format>%Y</format>
      <zIndex>10</zIndex>
    </datetime>

    <!-- 개발사 레이블 -->
    <text name="md_lbl_developer">
      <pos>0.545 0.584</pos>
      <size>0.09 0.026</size>
    </text>
    <!-- 개발사 -->
    <text name="md_developer">
      <fontPath>./_assets/fonts/Pretendard-Regular.ttf</fontPath>
      <pos>0.640 0.584</pos>
      <size>0.34 0.026</size>
      <fontSize>0.015</fontSize>
      <color>4A5568FF</color>
      <zIndex>10</zIndex>
    </text>

    <!-- 퍼블리셔 레이블 -->
    <text name="md_lbl_publisher">
      <pos>0.545 0.613</pos>
      <size>0.09 0.026</size>
    </text>
    <!-- 퍼블리셔 -->
    <text name="md_publisher">
      <fontPath>./_assets/fonts/Pretendard-Regular.ttf</fontPath>
      <pos>0.640 0.613</pos>
      <size>0.34 0.026</size>
      <fontSize>0.015</fontSize>
      <color>4A5568FF</color>
      <zIndex>10</zIndex>
    </text>

    <!-- 장르 레이블 -->
    <text name="md_lbl_genre">
      <pos>0.545 0.642</pos>
      <size>0.09 0.026</size>
    </text>
    <!-- 장르 -->
    <text name="md_genre">
      <fontPath>./_assets/fonts/Pretendard-Regular.ttf</fontPath>
      <pos>0.640 0.642</pos>
      <size>0.34 0.026</size>
      <fontSize>0.015</fontSize>
      <color>4A5568FF</color>
      <zIndex>10</zIndex>
    </text>

    <!-- 플레이어 수 레이블 -->
    <text name="md_lbl_players">
      <pos>0.545 0.671</pos>
      <size>0.09 0.026</size>
    </text>
    <!-- 플레이어 수 -->
    <text name="md_players">
      <fontPath>./_assets/fonts/Pretendard-Regular.ttf</fontPath>
      <pos>0.640 0.671</pos>
      <size>0.10 0.026</size>
      <fontSize>0.015</fontSize>
      <color>4A5568FF</color>
      <zIndex>10</zIndex>
    </text>

    <!-- 평점 레이블 -->
    <text name="md_lbl_rating">
      <pos>0.545 0.700</pos>
      <size>0.09 0.026</size>
    </text>
    <!-- 평점 -->
    <rating name="md_rating">
      <origin>0 0.5</origin>
      <pos>0.640 0.707</pos>
      <size>0.12 0.018</size>
      <color>4A8FE7FF</color>
      <zIndex>10</zIndex>
    </rating>

    <!-- 게임 설명 -->
    <text name="md_description">
      <pos>0.545 0.735</pos>
      <size>0.44 0.175</size>
      <fontSize>0.016</fontSize>
      <fontPath>./_assets/fonts/Pretendard-Regular.ttf</fontPath>
      <color>6B7A8EFF</color>
      <lineSpacing>1.5</lineSpacing>
      <zIndex>10</zIndex>
    </text>

    <!-- 플레이 횟수 (숨김) -->
    <text name="md_playcount">
      <pos>1.5 1.5</pos>
      <size>0 0</size>
    </text>

    <!-- 마지막 플레이 (숨김) -->
    <datetime name="md_lastplayed">
      <pos>1.5 1.5</pos>
      <size>0 0</size>
    </datetime>

    <!-- 마키 이미지 (숨김) -->
    <image name="md_marquee">
      <pos>1.5 1.5</pos>
      <size>0 0</size>
    </image>

    <!-- 도움말 -->
    <helpsystem name="help">
      <pos>0.19 0.975</pos>
      <fontSize>0.017</fontSize>
      <textColor>9CA8B7FF</textColor>
      <iconColor>4A8FE7FF</iconColor>
    </helpsystem>

  </view>

  <!-- 비디오 뷰 전용 -->
  <feature supported="video">
  <view name="video">

    <video name="md_video">
      <pos>0.762 0.295</pos>
      <origin>0.5 0.5</origin>
      <maxSize>0.44 0.40</maxSize>
      <delay>1.5</delay>
      <showSnapshotNoVideo>true</showSnapshotNoVideo>
      <showSnapshotDelay>true</showSnapshotDelay>
      <zIndex>10</zIndex>
    </video>

  </view>
  </feature>


  <!-- ===== SYSTEM VIEW ===== -->

