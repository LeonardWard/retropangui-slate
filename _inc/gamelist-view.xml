<?xml version="1.0"?>
<theme>
  <formatVersion>4</formatVersion>

  <!-- ===== GAMELIST VIEW (basic / detailed / video / grid) ===== -->
  <view name="basic, detailed, video, grid">

    <!-- 전체 배경 -->
    <image name="background" extra="true">
      <path>../_assets/white.png</path>
      <color>${colorBg}</color>
      <size>1920 1080</size>
      <pos>0 0</pos>
      <zIndex>0</zIndex>
    </image>

    <!-- 왼쪽 사이드바 -->
    <image name="sidebar" extra="true">
      <path>../_assets/white.png</path>
      <color>${colorSidebar}</color>
      <size>467 1080</size>
      <pos>0 0</pos>
      <zIndex>5</zIndex>
    </image>

    <!-- 상단 헤더바 (화이트) -->
    <image name="header-bar" extra="true">
      <path>../_assets/white.png</path>
      <color>${colorBg}</color>
      <size>1453 148</size>
      <pos>467 0</pos>
      <zIndex>6</zIndex>
    </image>

    <!-- 하단 풋터바 (화이트) -->
    <image name="footer-bar" extra="true">
      <path>../_assets/white.png</path>
      <color>${colorBg}</color>
      <size>1453 90</size>
      <pos>467 990</pos>
      <zIndex>6</zIndex>
    </image>

    <!-- 앱 로고 (사이드바 상단, 흰색) -->
    <image name="appname-logo" extra="true">
      <path>../_assets/logo-header.svg</path>
      <origin>0.5 0.5</origin>
      <pos>246 74</pos>
      <maxSize>442 95</maxSize>
      <zIndex>10</zIndex>
    </image>

    <!-- 헤더 하단 구분선 -->
    <image name="header-divider" extra="true">
      <path>../_assets/white.png</path>
      <color>00000000</color>
      <size>1453 2</size>
      <pos>467 148</pos>
      <zIndex>7</zIndex>
    </image>

    <!-- 하단 구분선 -->
    <image name="footer-divider" extra="true">
      <path>../_assets/white.png</path>
      <color>00000000</color>
      <size>1453 2</size>
      <pos>467 990</pos>
      <zIndex>7</zIndex>
    </image>

    <!-- 사이드바 세로 구분선 -->
    <image name="sidebar-divider" extra="true">
      <path>../_assets/white.png</path>
      <color>00000000</color>
      <size>2 842</size>
      <pos>467 148</pos>
      <zIndex>7</zIndex>
    </image>

    <!-- 헤더: 시스템 풀네임 - PF스타더스트 ExtraBold(픽셀폰트, 로고와 동일 계열)로 변경 -->
    <text name="systemfullname" extra="true">
      <origin>0 0.5</origin>
      <pos>499 74</pos>
      <size>960 65</size>
      <fontSize>35</fontSize>
      <fontPath>../_assets/fonts/PFStardust-ExtraBold.ttf</fontPath>
      <color>${colorDark}</color>
      <forceUppercase>1</forceUppercase>
      <zIndex>10</zIndex>
    </text>

    <!-- 리스트-디테일 구분선 -->
    <image name="list-detail-divider" extra="true">
      <path>../_assets/white.png</path>
      <color>${colorDivider}</color>
      <size>2 842</size>
      <pos>1087 148</pos>
      <zIndex>7</zIndex>
    </image>

    <!-- 사이드바 내 시스템 로고 - 좌측 상단 앱 로고와 너무 붙어 보여서 40px 아래로
         이동(2026-07-24) -->
    <image name="logo">
      <path>../_assets/logos/${system.theme}.svg</path>
      <origin>0.5 0.5</origin>
      <pos>233 256</pos>
      <maxSize>351 97</maxSize>
      <color>${colorLogo}</color>
      <zIndex>15</zIndex>
    </image>

    <!-- 사이드바: 시스템 짧은 설명 -->
    <text name="shortdescription" extra="true">
      <origin>0.5 0.5</origin>
      <pos>233 353</pos>
      <size>413 43</size>
      <fontSize>17</fontSize>
      <fontPath>../_assets/fonts/Pretendard-Regular.ttf</fontPath>
      <color>${colorGray2}</color>
      <alignment>center</alignment>
      <forceUppercase>0</forceUppercase>
      <zIndex>10</zIndex>
    </text>

    <!-- 사이드바: 시스템 상세 설명 (게임목록 화면 전용 - system view의 longdescription과 별개,
         더 길고 상세한 문구를 각 시스템 theme.xml에 직접 작성) -->
    <text name="overview" extra="true">
      <origin>0.5 0</origin>
      <pos>233 402</pos>
      <size>413 420</size>
      <fontSize>20</fontSize>
      <fontPath>../_assets/fonts/Pretendard-Regular.ttf</fontPath>
      <color>${colorGray3}</color>
      <lineSpacing>1.5</lineSpacing>
      <forceUppercase>0</forceUppercase>
      <alignment>center</alignment>
      <zIndex>10</zIndex>
    </text>

    <!-- longdescription 화면 밖으로 숨김 - 아직 overview를 안 넣은 시스템의
         theme.xml이 "system, basic, detailed, video, grid" 공용 뷰 범위에
         longdescription 콘텐츠를 계속 채우므로, 이 뷰에서 스타일 없이(기본값
         전체화면) 렌더링되는 걸 막기 위함. overview 도입 전 임시 조치. -->
    <text name="longdescription" extra="true">
      <pos>2880 1620</pos>
      <size>0 0</size>
    </text>

    <!-- 사이드바 하단: 시스템 정보 (게임 수 등) -->
    <text name="systemInfo">
      <origin>0.5 0.5</origin>
      <pos>233 865</pos>
      <size>413 65</size>
      <fontSize>18</fontSize>
      <fontPath>../_assets/fonts/Pretendard-Regular.ttf</fontPath>
      <color>${colorGray2}</color>
      <alignment>center</alignment>
      <zIndex>10</zIndex>
    </text>

    <!-- ── 게임 목록 ── -->
    <textlist name="gamelist">
      <pos>493 158</pos>
      <size>576 824</size>
      <primaryColor>4A5568FF</primaryColor>
      <secondaryColor>718096FF</secondaryColor>
      <selectedColor>2D5BE3FF</selectedColor>
      <selectorColor>E8F0FEEE</selectorColor>
      <selectorHeight>54</selectorHeight>
      <fontPath>../_assets/fonts/Pretendard-Regular.ttf</fontPath>
      <fontSize>28</fontSize>
      <alignment>left</alignment>
      <horizontalMargin>16</horizontalMargin>
      <lineSpacing>1.75</lineSpacing>
      <forceUppercase>0</forceUppercase>
      <zIndex>10</zIndex>
    </textlist>

    <!-- ── 우측 상세 패널 ── -->

    <!-- 게임 이름 (헤더 바로 아래) -->
    <!-- 게임 스크린샷 이미지 (이름보다 먼저 배치 - 이름은 이미지 아래로) -->
    <image name="md_image">
      <origin>0.5 0.5</origin>
      <pos>1503 367</pos>
      <maxSize>700 380</maxSize>
      <zIndex>10</zIndex>
    </image>

    <!-- 게임 이름 (이미지 아래) -->
    <text name="md_name">
      <pos>1114 572</pos>
      <size>778 44</size>
      <fontSize>26</fontSize>
      <fontPath>../_assets/fonts/Pretendard-Bold.ttf</fontPath>
      <color>${colorDark}</color>
      <zIndex>10</zIndex>
    </text>

    <!-- 메타데이터 레이블 공통 스타일 -->
    <text name="md_lbl_rating, md_lbl_developer, md_lbl_publisher, md_lbl_players, md_lbl_releasedate, md_lbl_genre">
      <fontPath>../_assets/fonts/Pretendard-Regular.ttf</fontPath>
      <fontSize>20</fontSize>
      <color>${colorGray1}</color>
      <forceUppercase>0</forceUppercase>
      <zIndex>10</zIndex>
    </text>

    <!-- 출시일 레이블 -->
    <text name="md_lbl_releasedate">
      <pos>1114 630</pos>
      <size>180 32</size>
    </text>
    <!-- 출시일 -->
    <datetime name="md_releasedate">
      <fontPath>../_assets/fonts/Pretendard-Regular.ttf</fontPath>
      <pos>1300 630</pos>
      <size>178 32</size>
      <fontSize>20</fontSize>
      <color>${colorGray3}</color>
      <format>%Y</format>
      <zIndex>10</zIndex>
    </datetime>

    <!-- 개발사 레이블 -->
    <text name="md_lbl_developer">
      <pos>1114 666</pos>
      <size>180 32</size>
    </text>
    <!-- 개발사 -->
    <text name="md_developer">
      <fontPath>../_assets/fonts/Pretendard-Regular.ttf</fontPath>
      <pos>1300 666</pos>
      <size>578 32</size>
      <fontSize>20</fontSize>
      <color>${colorGray3}</color>
      <zIndex>10</zIndex>
    </text>

    <!-- 퍼블리셔 레이블 -->
    <text name="md_lbl_publisher">
      <pos>1114 702</pos>
      <size>180 32</size>
    </text>
    <!-- 퍼블리셔 -->
    <text name="md_publisher">
      <fontPath>../_assets/fonts/Pretendard-Regular.ttf</fontPath>
      <pos>1300 702</pos>
      <size>578 32</size>
      <fontSize>20</fontSize>
      <color>${colorGray3}</color>
      <zIndex>10</zIndex>
    </text>

    <!-- 장르 레이블 -->
    <text name="md_lbl_genre">
      <pos>1114 738</pos>
      <size>180 32</size>
    </text>
    <!-- 장르 -->
    <text name="md_genre">
      <fontPath>../_assets/fonts/Pretendard-Regular.ttf</fontPath>
      <pos>1300 738</pos>
      <size>578 32</size>
      <fontSize>20</fontSize>
      <color>${colorGray3}</color>
      <zIndex>10</zIndex>
    </text>

    <!-- 플레이어 수 레이블 -->
    <text name="md_lbl_players">
      <pos>1114 774</pos>
      <size>180 32</size>
    </text>
    <!-- 플레이어 수 -->
    <text name="md_players">
      <fontPath>../_assets/fonts/Pretendard-Regular.ttf</fontPath>
      <pos>1300 774</pos>
      <size>178 32</size>
      <fontSize>20</fontSize>
      <color>${colorGray3}</color>
      <zIndex>10</zIndex>
    </text>

    <!-- 평점 레이블 -->
    <text name="md_lbl_rating">
      <pos>1114 810</pos>
      <size>180 32</size>
    </text>
    <!-- 평점 -->
    <rating name="md_rating">
      <origin>0 0.5</origin>
      <pos>1300 817</pos>
      <size>211 22</size>
      <color>${colorBlue}</color>
      <zIndex>10</zIndex>
    </rating>

    <!-- 게임 설명 -->
    <text name="md_description">
      <pos>1114 858</pos>
      <size>778 150</size>
      <fontSize>20</fontSize>
      <fontPath>../_assets/fonts/Pretendard-Regular.ttf</fontPath>
      <color>${colorGray2}</color>
      <lineSpacing>1.5</lineSpacing>
      <scrollable>true</scrollable>
      <zIndex>10</zIndex>
    </text>

    <!-- 플레이 횟수 (숨김) -->
    <text name="md_playcount">
      <pos>2880 1620</pos>
      <size>0 0</size>
    </text>

    <!-- 마지막 플레이 (숨김) -->
    <datetime name="md_lastplayed">
      <pos>2880 1620</pos>
      <size>0 0</size>
    </datetime>

    <!-- 마키 이미지 (숨김) -->
    <image name="md_marquee">
      <pos>2880 1620</pos>
      <size>0 0</size>
    </image>

    <!-- 도움말 (하단 풋터 세로 중앙) -->
    <helpsystem name="help">
      <pos>499 1026</pos>
      <fontSize>26</fontSize>
      <textColor>9CA8B7FF</textColor>
      <iconColor>4A8FE7FF</iconColor>
    </helpsystem>

  </view>

  <!-- 비디오 뷰 전용 -->
  <feature supported="video">
  <view name="video">

    <!-- video 뷰에서 md_image 숨김 (video 요소가 스냅샷 담당) -->
    <image name="md_image">
      <pos>2880 1620</pos>
      <size>0 0</size>
    </image>

    <video name="md_video">
      <pos>1503 367</pos>
      <origin>0.5 0.5</origin>
      <maxSize>614 302</maxSize>
      <delay>1.5</delay>
      <showSnapshotNoVideo>true</showSnapshotNoVideo>
      <showSnapshotDelay>true</showSnapshotDelay>
      <zIndex>10</zIndex>
    </video>

  </view>
  </feature>
</theme>
