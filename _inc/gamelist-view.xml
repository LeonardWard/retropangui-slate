<?xml version="1.0"?>
<theme>
  <formatVersion>4</formatVersion>

  <view name="basic, detailed, video, grid">

    <!-- 전체 배경 -->
    <image name="background" extra="true">
      <color>EEF1F7FF</color>
      <size>1 1</size>
      <pos>0 0</pos>
      <zIndex>0</zIndex>
    </image>

    <!-- 왼쪽 다크 사이드바 -->
    <image name="sidebar" extra="true">
      <color>1A1E2DFF</color>
      <size>0.21 1.0</size>
      <pos>0 0</pos>
      <zIndex>5</zIndex>
    </image>

    <!-- 상단 헤더바 (화이트) -->
    <image name="header-bar" extra="true">
      <color>FFFFFFFF</color>
      <size>0.79 0.065</size>
      <pos>0.21 0</pos>
      <zIndex>6</zIndex>
    </image>

    <!-- 헤더 구분선 -->
    <image name="header-divider" extra="true">
      <color>D5DAE6FF</color>
      <size>1.0 0.002</size>
      <pos>0 0.063</pos>
      <zIndex>7</zIndex>
    </image>

    <!-- 사이드바 세로 구분선 -->
    <image name="sidebar-divider" extra="true">
      <color>D5DAE6FF</color>
      <size>0.001 0.935</size>
      <pos>0.21 0.065</pos>
      <zIndex>7</zIndex>
    </image>

    <!-- 리스트-디테일 구분선 -->
    <image name="list-detail-divider" extra="true">
      <color>D5DAE6FF</color>
      <size>0.001 0.935</size>
      <pos>0.60 0.065</pos>
      <zIndex>7</zIndex>
    </image>

    <!-- 사이드바 내 시스템 로고 -->
    <image name="logo">
      <origin>0.5 0.5</origin>
      <pos>0.105 0.09</pos>
      <maxSize>0.17 0.07</maxSize>
      <color>FFFFFFFF</color>
      <zIndex>15</zIndex>
    </image>

    <!-- 사이드바: 시스템 짧은 설명 -->
    <text name="shortdescription" extra="true">
      <origin>0.5 0.5</origin>
      <pos>0.105 0.19</pos>
      <size>0.19 0.03</size>
      <fontSize>0.016</fontSize>
      <fontPath>../_assets/fonts/Pretendard-Regular.ttf</fontPath>
      <color>9CA8B7FF</color>
      <alignment>center</alignment>
      <forceUppercase>0</forceUppercase>
      <zIndex>10</zIndex>
    </text>

    <!-- 사이드바: 시스템 상세 설명 (게임목록 화면 전용 - system view의 longdescription과 별개,
         더 길고 상세한 문구를 각 시스템 theme.xml에 직접 작성) -->
    <text name="overview" extra="true">
      <origin>0.5 0</origin>
      <pos>0.105 0.23</pos>
      <size>0.19 0.45</size>
      <fontSize>0.020</fontSize>
      <fontPath>../_assets/fonts/Pretendard-Regular.ttf</fontPath>
      <color>6B7A8EFF</color>
      <lineSpacing>1.5</lineSpacing>
      <forceUppercase>0</forceUppercase>
      <alignment>center</alignment>
      <scrollable>true</scrollable>
      <zIndex>10</zIndex>
    </text>

    <!-- 사이드바 하단: 시스템 정보 -->
    <text name="systemInfo">
      <origin>0.5 0.5</origin>
      <pos>0.105 0.78</pos>
      <size>0.19 0.05</size>
      <fontSize>0.017</fontSize>
      <fontPath>../_assets/fonts/Pretendard-Regular.ttf</fontPath>
      <color>9CA8B7FF</color>
      <alignment>center</alignment>
      <zIndex>10</zIndex>
    </text>

    <!-- bgmTitle은 2026-07-06부로 메인 화면(system 뷰) 푸터 우측으로 이동 -
         게임리스트 화면에서는 안 보여주기로 함(theme.xml 참고) -->

    <!-- 게임 목록 -->
    <textlist name="gamelist">
      <pos>0.225 0.08</pos>
      <size>0.365 0.85</size>
      <primaryColor>BBBBCCFF</primaryColor>
      <secondaryColor>888899FF</secondaryColor>
      <selectedColor>4A8FE7FF</selectedColor>
      <selectorColor>E5EFFEEE</selectorColor>
      <selectorHeight>0.048</selectorHeight>
      <fontPath>../_assets/fonts/Pretendard-Regular.ttf</fontPath>
      <fontSize>0.026</fontSize>
      <alignment>left</alignment>
      <horizontalMargin>0.02</horizontalMargin>
      <lineSpacing>1.75</lineSpacing>
      <forceUppercase>0</forceUppercase>
      <zIndex>10</zIndex>
    </textlist>

    <!-- 게임 스크린샷 이미지 -->
    <image name="md_image">
      <origin>0.5 0.5</origin>
      <pos>0.80 0.34</pos>
      <maxSize>0.37 0.37</maxSize>
      <zIndex>10</zIndex>
    </image>

    <!-- 게임 이름 -->
    <text name="md_name">
      <pos>0.62 0.072</pos>
      <size>0.37 0.035</size>
      <fontSize>0.022</fontSize>
      <fontPath>../_assets/fonts/Pretendard-Bold.ttf</fontPath>
      <color>1A1E2DFF</color>
      <zIndex>10</zIndex>
    </text>

    <!-- 메타데이터 레이블 공통 스타일 -->
    <text name="md_lbl_rating, md_lbl_developer, md_lbl_publisher, md_lbl_players, md_lbl_releasedate, md_lbl_genre">
      <fontPath>../_assets/fonts/Pretendard-Regular.ttf</fontPath>
      <fontSize>0.016</fontSize>
      <color>9CA8B7FF</color>
      <forceUppercase>0</forceUppercase>
      <zIndex>10</zIndex>
    </text>

    <!-- 평점 레이블 -->
    <text name="md_lbl_rating">
      <pos>0.615 0.56</pos>
      <size>0.08 0.025</size>
    </text>

    <!-- 평점 -->
    <rating name="md_rating">
      <origin>0 0.5</origin>
      <pos>0.685 0.563</pos>
      <size>0.10 0.018</size>
      <color>4A8FE7FF</color>
      <zIndex>10</zIndex>
    </rating>

    <!-- 개발사 레이블 -->
    <text name="md_lbl_developer">
      <pos>0.615 0.59</pos>
      <size>0.08 0.025</size>
    </text>

    <!-- 개발사 -->
    <text name="md_developer">
      <fontPath>../_assets/fonts/Pretendard-Regular.ttf</fontPath>
      <pos>0.695 0.590</pos>
      <size>0.28 0.025</size>
      <fontSize>0.016</fontSize>
      <color>6B7A8EFF</color>
      <zIndex>10</zIndex>
    </text>

    <!-- 퍼블리셔 레이블 -->
    <text name="md_lbl_publisher">
      <pos>0.615 0.615</pos>
      <size>0.08 0.025</size>
    </text>

    <!-- 퍼블리셔 -->
    <text name="md_publisher">
      <fontPath>../_assets/fonts/Pretendard-Regular.ttf</fontPath>
      <pos>0.695 0.615</pos>
      <size>0.28 0.025</size>
      <fontSize>0.016</fontSize>
      <color>6B7A8EFF</color>
      <zIndex>10</zIndex>
    </text>

    <!-- 플레이어 수 레이블 -->
    <text name="md_lbl_players">
      <pos>0.615 0.640</pos>
      <size>0.08 0.025</size>
    </text>

    <!-- 플레이어 수 -->
    <text name="md_players">
      <fontPath>../_assets/fonts/Pretendard-Regular.ttf</fontPath>
      <pos>0.695 0.640</pos>
      <size>0.10 0.025</size>
      <fontSize>0.016</fontSize>
      <color>6B7A8EFF</color>
      <zIndex>10</zIndex>
    </text>

    <!-- 출시일 레이블 -->
    <text name="md_lbl_releasedate">
      <pos>0.615 0.665</pos>
      <size>0.10 0.025</size>
    </text>

    <!-- 출시일 -->
    <datetime name="md_releasedate">
      <fontPath>../_assets/fonts/Pretendard-Regular.ttf</fontPath>
      <pos>0.695 0.665</pos>
      <size>0.10 0.025</size>
      <fontSize>0.016</fontSize>
      <color>6B7A8EFF</color>
      <format>%Y</format>
      <zIndex>10</zIndex>
    </datetime>

    <!-- 장르 레이블 -->
    <text name="md_lbl_genre">
      <pos>0.615 0.690</pos>
      <size>0.08 0.025</size>
    </text>

    <!-- 장르 -->
    <text name="md_genre">
      <fontPath>../_assets/fonts/Pretendard-Regular.ttf</fontPath>
      <pos>0.695 0.690</pos>
      <size>0.20 0.025</size>
      <fontSize>0.016</fontSize>
      <color>6B7A8EFF</color>
      <zIndex>10</zIndex>
    </text>

    <!-- 게임 설명 -->
    <text name="md_description">
      <pos>0.615 0.72</pos>
      <size>0.365 0.20</size>
      <fontSize>0.032</fontSize>
      <fontPath>../_assets/fonts/Pretendard-Regular.ttf</fontPath>
      <color>6B7A8EFF</color>
      <lineSpacing>1.5</lineSpacing>
      <scrollable>true</scrollable>
      <zIndex>10</zIndex>
    </text>

    <!-- 플레이 횟수 (숨김) -->
    <text name="md_playcount">
      <pos>1.5 1.5</pos>
      <size>0 0</size>
    </text>

    <!-- 마지막 플레이 (숨김) -->
    <datetime name="md_lastplayed">
      <pos>1.5 1.5</pos>
      <size>0 0</size>
    </datetime>

    <!-- 마키 이미지 (숨김) -->
    <image name="md_marquee">
      <pos>1.5 1.5</pos>
      <size>0 0</size>
    </image>

    <!-- 도움말 시스템 -->
    <helpsystem name="help">
      <pos>0.22 0.975</pos>
      <fontSize>0.018</fontSize>
      <textColor>9CA8B7FF</textColor>
      <iconColor>4A8FE7FF</iconColor>
    </helpsystem>

  </view>

  <!-- 비디오 뷰 전용 -->
  <feature supported="video">
  <view name="video">

    <video name="md_video">
      <pos>0.80 0.34</pos>
      <origin>0.5 0.5</origin>
      <maxSize>0.30 0.37</maxSize>
      <delay>1.5</delay>
      <fadeTime>0.5</fadeTime>
      <showSnapshotNoVideo>true</showSnapshotNoVideo>
      <showSnapshotDelay>true</showSnapshotDelay>
      <zIndex>10</zIndex>
    </video>

  </view>
  </feature>

</theme>
