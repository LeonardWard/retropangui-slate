      <path>../_assets/white.png</path>
      <color>${colorBg}</color>
      <size>1453 90</size>
      <pos>467 990</pos>
      <zIndex>6</zIndex>
    </image>

    <!-- 헤더 하단 구분선 -->
    <image name="header-divider" extra="true">
      <path>../_assets/white.png</path>
      <color>00000000</color>
      <size>1453 2</size>
      <pos>467 148</pos>
      <zIndex>7</zIndex>
    </image>

    <!-- 하단 구분선 -->
    <image name="footer-divider" extra="true">
      <path>../_assets/white.png</path>
      <color>00000000</color>
      <size>1453 2</size>
      <pos>467 990</pos>
      <zIndex>7</zIndex>
    </image>

    <!-- 사이드바-메인 세로 구분선 -->
    <image name="sidebar-divider" extra="true">
      <path>../_assets/white.png</path>
      <color>00000000</color>
      <size>2 842</size>
      <pos>467 148</pos>
      <zIndex>7</zIndex>
    </image>

