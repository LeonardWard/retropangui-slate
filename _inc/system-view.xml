      <lineSpacing>1.6</lineSpacing>
      <forceUppercase>0</forceUppercase>
      <scrollable>true</scrollable>
      <zIndex>10</zIndex>
    </text>

    <!-- 5. 스탯 행: 컨트롤러 아이콘 배경 원 (중심 0.289, 오른쪽 끝 0.3025)
         2026-07-11: RECENTLY PLAYED 섹션(y 737~965)이 나중에 이 자리(y 864
         중심)에 그대로 얹히면서 서로 겹쳐 스탯 행이 가려지는 문제 발견 -
         longdescription이 끝나는 y≈599와 RECENTLY PLAYED 헤더가 시작하는
         y=737 사이 빈 공간(138px)으로 전체 행을 끌어올림(중심 864→670,
         delta -194 - 그룹 내 모든 요소에 동일 적용해서 상대 배치는 그대로). -->
    <image name="icon-controller-bg" extra="true">
      <path>../_assets/circle-white.svg</path>
      <origin>0.5 0.5</origin>
      <pos>555 670</pos>
      <size>52 52</size>
      <zIndex>9</zIndex>
    </image>

