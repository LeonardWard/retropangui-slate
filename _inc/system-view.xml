    <!-- 2. 시스템 풀네임 부제목 → systemfullname 필드 (각 시스템 theme.xml에서 채움) -->
    <text name="systemfullname" extra="true">
      <origin>0 0</origin>
      <pos>532 346</pos>
      <size>806 43</size>
      <fontSize>35</fontSize>
      <fontPath>../_assets/fonts/Pretendard-Bold.ttf</fontPath>
      <color>${colorAccent}</color>
      <forceUppercase>1</forceUppercase>
      <zIndex>10</zIndex>
    </text>

    <!-- 3. 구분선 1 -->
    <image name="content-divider-1" extra="true">
      <path>../_assets/white.png</path>
      <color>${colorAccent}</color>
      <size>115 3</size>
      <pos>532 403</pos>
      <zIndex>10</zIndex>
    </image>

    <!-- 4. 짧은 정보 (연도·제조사·플랫폼) → shortdescription 필드 -->
    <text name="shortdescription" extra="true">
      <origin>0 0</origin>
      <pos>532 434</pos>
      <size>806 32</size>
      <fontSize>18</fontSize>
      <fontPath>../_assets/fonts/Pretendard-Regular.ttf</fontPath>
      <color>${colorGray1}</color>
      <forceUppercase>0</forceUppercase>
      <zIndex>10</zIndex>
    </text>

    <!-- 5. 긴 설명 → longdescription 필드 -->
