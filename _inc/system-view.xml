      <pos>1548 572</pos>
      <origin>0.5 0.5</origin>
      <maxSize>998 756</maxSize>
      <zIndex>10</zIndex>
    </image>

    <!-- ═══ 메인 콘텐츠 레이아웃 (x_start=532px=0.277) ═══ -->

    <!-- 1. 시스템 로고 (대형 타이틀) — extra로 충돌 방지 -->
