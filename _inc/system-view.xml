    -->

    <!-- 콘솔 영역 레이어 2: 파란 글로우 (스크린샷 위) — 주석처리 -->
    <!--
    <image name="console-glow" extra="true">
      <path>../_assets/console-glow.svg</path>
      <pos>1548 510</pos>
      <origin>0.5 0.5</origin>
      <size>730 540</size>
      <zIndex>9</zIndex>
    </image>
    -->

    <!-- 콘솔 영역 레이어 3: 콘솔 아트 이미지 (2x 크기) -->
