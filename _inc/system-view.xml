    <text name="systemInfo">
      <visible>false</visible>
    </text>

    <!-- 6a. 스탯 행: 게임 수 숫자 — 상단 행 (크게, 볼드) -->
    <text name="gameCountNumber">
      <origin>0 0.5</origin>
      <pos>599 656</pos>
      <size>288 36</size>
