<?xml version="1.0"?>
<theme>
  <formatVersion>4</formatVersion>

  <view name="system">

    <!-- 전체 배경 -->
    <image name="background" extra="true">
      <color>EEF1F7FF</color>
      <size>1 1</size>
      <pos>0 0</pos>
      <zIndex>0</zIndex>
    </image>

    <!-- 왼쪽 다크 사이드바 -->
    <image name="sidebar" extra="true">
      <color>1A1E2DFF</color>
      <size>0.19 1.0</size>
      <pos>0 0</pos>
      <zIndex>5</zIndex>
    </image>

    <!-- 사이드바 상단 헤더 (더 어두운 색) -->
    <image name="sidebar-header" extra="true">
      <color>151928FF</color>
      <size>0.19 0.065</size>
      <pos>0 0</pos>
      <zIndex>6</zIndex>
    </image>

    <!-- 메인 헤더바 (화이트) -->
    <image name="main-header" extra="true">
      <color>FFFFFFEF</color>
      <size>0.81 0.065</size>
      <pos>0.19 0</pos>
      <zIndex>6</zIndex>
    </image>

    <!-- 헤더 하단 구분선 -->
    <image name="header-divider" extra="true">
      <color>D5DAE6FF</color>
      <size>1.0 0.002</size>
      <pos>0 0.063</pos>
      <zIndex>7</zIndex>
    </image>

    <!-- 사이드바-메인 세로 구분선 -->
    <image name="sidebar-divider" extra="true">
      <color>D5DAE6FF</color>
      <size>0.001 0.935</size>
      <pos>0.19 0.065</pos>
      <zIndex>7</zIndex>
    </image>

    <!-- 앱 이름 텍스트 -->
    <text name="appname" extra="true">
      <text>RETROPANGUI-C5</text>
      <pos>0.225 0.033</pos>
      <origin>0 0.5</origin>
      <fontSize>0.025</fontSize>
      <fontPath>../_assets/fonts/Pretendard-Bold.ttf</fontPath>
      <color>1A1E2DFF</color>
      <forceUppercase>1</forceUppercase>
      <zIndex>10</zIndex>
    </text>

    <!-- 콘솔 아트 이미지 -->
    <image name="console-art" extra="true">
      <path>../_assets/consoles/${system.theme}.png</path>
      <pos>0.81 0.44</pos>
      <origin>0.5 0.5</origin>
      <maxSize>0.27 0.30</maxSize>
      <zIndex>10</zIndex>
    </image>

  </view>

  <!-- 캐러셀 지원 시 시스템 선택 -->
  <feature supported="carousel">
  <view name="system">

    <!-- 시스템 선택 캐러셀 (세로형, 좌측 사이드바) -->
    <carousel name="systemcarousel">
      <type>vertical</type>
      <pos>0.095 0.55</pos>
      <origin>0.5 0.5</origin>
      <size>0.19 0.73</size>
      <color>00000000</color>
      <colorEnd>00000000</colorEnd>
      <logoSize>0.165 0.05</logoSize>
      <logoScale>1.15</logoScale>
      <maxLogoCount>9</maxLogoCount>
      <zIndex>20</zIndex>
    </carousel>

    <!-- 큰 시스템 로고 (중앙 배치) -->
    <image name="logo">
      <origin>0.5 0.5</origin>
      <pos>0.48 0.20</pos>
      <maxSize>0.30 0.12</maxSize>
      <zIndex>15</zIndex>
    </image>

  </view>
  </feature>

  <view name="system">

    <!-- 시스템 짧은 설명 -->
    <text name="shortdescription" extra="true">
      <origin>0 0.5</origin>
      <pos>0.23 0.37</pos>
      <size>0.40 0.04</size>
      <fontSize>0.020</fontSize>
      <fontPath>../_assets/fonts/Pretendard-Regular.ttf</fontPath>
      <color>6B7A8EFF</color>
      <forceUppercase>0</forceUppercase>
      <zIndex>10</zIndex>
    </text>

    <!-- 시스템 긴 설명 -->
    <text name="longdescription" extra="true">
      <origin>0 0</origin>
      <pos>0.23 0.43</pos>
      <size>0.34 0.16</size>
      <fontSize>0.022</fontSize>
      <fontPath>../_assets/fonts/Pretendard-Regular.ttf</fontPath>
      <color>6B7A8EFF</color>
      <lineSpacing>1.6</lineSpacing>
      <forceUppercase>0</forceUppercase>
      <verticalAlignment>top</verticalAlignment>
      <zIndex>10</zIndex>
    </text>

    <!-- 시스템 정보 (게임 수 등) -->
    <text name="systemInfo">
      <origin>0 0.5</origin>
      <pos>0.23 0.67</pos>
      <size>0.35 0.03</size>
      <fontSize>0.019</fontSize>
      <fontPath>../_assets/fonts/Pretendard-Regular.ttf</fontPath>
      <color>9CA8B7FF</color>
      <zIndex>10</zIndex>
    </text>

    <!-- 도움말 시스템 -->
    <helpsystem name="help">
      <pos>0.20 0.975</pos>
      <fontSize>0.019</fontSize>
      <textColor>9CA8B7FF</textColor>
      <iconColor>4A8FE7FF</iconColor>
    </helpsystem>

  </view>

</theme>
