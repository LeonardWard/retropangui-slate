<?xml version="1.0"?>
<theme>
  <formatVersion>4</formatVersion>

  <!-- ===== SYSTEM VIEW ===== -->

  <view name="system">

    <!-- 전체 배경 -->
    <image name="background" extra="true">
      <path>../_assets/white.png</path>
      <color>${colorBg}</color>
      <size>1920 1080</size>
      <pos>0 0</pos>
      <zIndex>0</zIndex>
    </image>

    <!-- 시스템 실루엣 이미지 - 2026-07-17: 복사본이 아니라 실제 스크린샷
         파일을 exec 변수(latestScreenshot, 위 <variables> 참고)로 직접
         가리킴. 스크린샷이 아직 없는 시스템은 <default> 없이 빈 화면. -->
    <image name="system-silhouette" extra="true">
      <path>${latestScreenshot}</path>
      <origin>1 0</origin>
      <pos>1920 0</pos>
      <maxSize>550 700</maxSize>
      <zIndex>7</zIndex>
    </image>

    <!-- 실루엣 하단 페이드 -->
    <image name="silhouette-fade" extra="true">
      <path>../_assets/bg-fade.png</path>
      <pos>1183 460</pos>
      <size>737 300</size>
      <zIndex>7</zIndex>
    </image>

    <!-- 실루엣 클립 마스크 (사다리꼴 바깥 가림) -->
    <image name="silhouette-clip" extra="true">
      <path>../_assets/bg-clip-mask.png</path>
      <pos>1183 0</pos>
      <size>737 760</size>
      <zIndex>7</zIndex>
    </image>

    <!-- 우측 상단 배경 오브젝트 -->
    <image name="bg-object" extra="true">
      <path>../_assets/bg-object.png</path>
      <pos>1183 0</pos>
      <size>737 760</size>
      <zIndex>8</zIndex>
    </image>

    <!-- 사이드바 받침 (안전망): sidebar-rounded.svg 가장자리 안티앨리어싱이
         혹시라도 남아있을 경우를 대비해 같은 색(colorSidebar) 받침을 SVG
         바로 뒤에 깔아둠 - 라운딩 곡선(x≈436~467)은 제외한 평평한 구간까지만
         (0~430), 그 이상 덮으면 라운딩 효과 자체가 안 보이게 사라짐. -->
    <image name="sidebar-backing" extra="true">
      <path>../_assets/white.png</path>
      <color>${colorSidebar}</color>
      <size>430 990</size>
      <pos>0 0</pos>
      <zIndex>4</zIndex>
    </image>

    <!-- 왼쪽 사이드바 (하단 우측 모서리 라운드)
         2026-07-11: 캐러셀-풋터 경계 미세한 선의 진짜 원인 - sidebar-rounded.svg의
         viewBox(원래 243x917)가 실제 렌더 크기(467x990)와 종횡비가 안 맞아서
         (0.265 vs 0.471) 가로세로 다르게 늘어나 그려지고 있었고, 특히 우측
         하단 라운드 곡선이 이 왜곡 때문에 지저분하게 래스터화됐던 것으로
         추정 - viewBox를 467x990에 맞게 다시 그려서(_assets/sidebar-rounded.svg)
         왜곡 자체를 없앰(형태는 원래와 동일 비율로 유지, git 커밋 이력 확인
         결과 이 왜곡은 이 SVG가 처음 도입된 시점부터 계속 있었음). -->
    <image name="sidebar" extra="true">
      <path>../_assets/sidebar-rounded.svg</path>
      <size>467 990</size>
      <pos>0 0</pos>
      <zIndex>5</zIndex>
    </image>

    <!-- 사이드바 상단 헤더 (로고 영역, 같은 색) -->
    <image name="sidebar-header" extra="true">
      <path>../_assets/white.png</path>
      <color>${colorSidebar}</color>
      <size>467 148</size>
      <pos>0 0</pos>
      <zIndex>6</zIndex>
    </image>

    <!-- 사이드바 하단 풋터 (흰색) -->
